{
  "manifest_version": 3,
  "name": "ThreatCaddy — Quick Capture",
  "version": "1.0.0",
  "description": "Quick-capture web content and proxy AI requests for ThreatCaddy threat intelligence. All data stays local on your device.",

  "browser_specific_settings": {
    "gecko": {
      "id": "threatcaddy@threatcaddy.com",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "optional_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*",
    "*://*/*",
    "file:///*"
  ],

  "content_scripts": [{
    "matches": [
      "https://threatcaddy.com/*",
      "https://www.threatcaddy.com/*",
      "http://localhost/*",
      "http://localhost:*/*",
      "http://127.0.0.1/*",
      "http://127.0.0.1:*/*"
    ],
    "js": ["bridge.js"],
    "run_at": "document_idle"
  }],

  "commands": {
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+X",
        "mac": "MacCtrl+Shift+X"
      },
      "description": "Capture selected text or full page"
    }
  }
}
